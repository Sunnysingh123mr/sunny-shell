export component AppWindow inherits Window {
    width: 1350px;
    height: 40px;
    background: transparent;
    always-on-top: true;
    no-frame: true;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 5px;
        padding-bottom: 5px;
        spacing: 10px;
        alignment: space-between;

        // ============================================================
        // LEFT AREA
        // ============================================================
        Rectangle {
            background: transparent;
            HorizontalLayout {
                spacing: 5px;
                alignment: center;

                // WIDGET 1: LAUNCHER (Light Grey Glass)
                Rectangle {
                    background: #33333366; // Mid-grey glass
                    border-radius: 16px;
                    border-width: 1px;
                    border-color: #ffffff1a;
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 5px;
                        padding-right: 8px;
                        alignment: center;

                        Text {
                            text: "";
                            color: #eeeeee;
                            font-size: 18px;
                            min-width: 20px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // WIDGET 2: WORKSPACES (Dark Grey Glass)
                Rectangle {
                    background: #33333366; // Smoky grey glass
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #ffffff0d;
                    height: 28px;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 6px;
                        alignment: center;

                        for i in [1, 2, 3] : Rectangle {
                            width: i == 1 ? 22px : 17px;
                            height: 10px;
                            background: i == 1 ? #ddddddcc : #66666666;
                            border-radius: 5px;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                }

                // WIDGET 3: WINDOW TITLE
                Rectangle {
                    background: #44444433;
                    border-radius: 10px;
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        alignment: center;
                        Text {
                            text: "Neovim ~ main.cpp";
                            color: #cccccc;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ============================================================
        // MIDDLE AREA
        // ============================================================
        Rectangle {
            background: transparent;
            HorizontalLayout {
                alignment: center;

                Rectangle {
                    background: #33333380;
                    border-radius: 14px;
                    border-width: 1px;
                    border-color: #ffffff1a;
                    height: 30px;
                    HorizontalLayout {
                        alignment: center;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            alignment: center;
                            Text {
                                text: "10:30 AM";
                                color: #d8e3db;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 1px;
                            height: 14px;
                            background: #66666680;
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 12px;
                            alignment: center;
                            Text {
                                text: "Tue, Mar 24";
                                color: #999999;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // ============================================================
        // RIGHT AREA
        // ============================================================
        Rectangle {
            background: transparent;
            HorizontalLayout {
                spacing: 6px;
                alignment: center;

                // CLIPBOARD
                Rectangle {
                    background: #33333366;
                    border-radius: 12px;
                    width: 35px;
                    height: 30px;
                    Text {
                        text: "󰅍";
                        color: #bbbbbb;
                        font-size: 17px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        min-width: 17px;
                    }
                }

                // NOTIFICATIONS
                Rectangle {
                    background: #33333366;
                    border-radius: 12px;
                    width: 35px;
                    height: 30px;
                    Text {
                        text: "󰂚";
                        color: #bbbbbb;
                        font-size: 17px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        min-width: 17px;
                    }
                }

                // CPU
                Rectangle {
                    background: #33333366;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: #ffffff0d;
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 12px;
                        alignment: center;
                        spacing: 5px;
                        Text {
                            text: "";
                            color: #cccccc;
                            font-size: 14px;
                            min-width: 14px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "12%";
                            color: #aaaaaa;
                            font-size: 12.5px;
                            vertical-alignment: center;
                        }
                    }
                }

                // RAM
                Rectangle {
                    background: #33333366;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: #ffffff0d;
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 12px;
                        alignment: center;
                        spacing: 6px;
                        Text {
                            text: "";
                            color: #cccccc;
                            font-size: 14px;
                            min-width: 10px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "2.4G";
                            color: #aaaaaa;
                            font-size: 12.5px;
                            vertical-alignment: center;
                        }
                    }
                }

                // CONNECTIVITY
                Rectangle {
                    background: #33333366;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #ffffff1a;
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;
                        alignment: center;
                        Text { text: "󰤨"; color: #eeeeee; font-size: 14px; min-width: 13px; vertical-alignment: center; }
                        Text { text: "󰂯"; color: #eeeeee; font-size: 14px; min-width: 0px; vertical-alignment: center; }
                        Text { text: "󰕾"; color: #eeeeee; font-size: 14px; min-width: 11px; vertical-alignment: center; }
                    }
                }
            }
        }
    }
}
